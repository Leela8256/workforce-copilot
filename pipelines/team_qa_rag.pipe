{
  "components": [
    {
      "id": "chat_1",
      "provider": "chat",
      "config": {
        "hideForm": true,
        "mode": "Source",
        "parameters": {},
        "type": "chat"
      },
      "ui": { "position": { "x": 20, "y": 200 }, "measured": { "width": 150, "height": 66 } }
    },
    {
      "id": "embedding_1",
      "provider": "embedding_openai",
      "config": {
        "profile": "text-embedding-3-small",
        "text-embedding-3-small": { "apikey": "${ROCKETRIDE_OPENAI_KEY}" },
        "parameters": {}
      },
      "input": [{ "lane": "questions", "from": "chat_1" }],
      "ui": { "position": { "x": 240, "y": 200 }, "measured": { "width": 150, "height": 66 } }
    },
    {
      "id": "qdrant_1",
      "provider": "qdrant",
      "config": {
        "profile": "local",
        "local": {
          "host": "localhost",
          "port": 6333,
          "collection": "jira_history",
          "score": 0.3
        },
        "parameters": {}
      },
      "input": [{ "lane": "questions", "from": "embedding_1" }],
      "ui": { "position": { "x": 460, "y": 200 }, "measured": { "width": 150, "height": 135 } }
    },
    {
      "id": "prompt_1",
      "provider": "prompt",
      "config": {
        "instructions": [
          "You are answering questions about a team's past Jira tickets and resolutions. Use ONLY the retrieved ticket context to answer. If no context is relevant, say so honestly. Always cite the ticket key (e.g. KAN-12) when referencing prior work."
        ],
        "parameters": {}
      },
      "input": [
        { "lane": "documents", "from": "qdrant_1" },
        { "lane": "questions", "from": "qdrant_1" }
      ],
      "ui": { "position": { "x": 680, "y": 200 }, "measured": { "width": 150, "height": 66 } }
    },
    {
      "id": "llm_1",
      "provider": "llm_openai",
      "config": {
        "profile": "openai-4o",
        "openai-4o": { "apikey": "${ROCKETRIDE_OPENAI_KEY}" },
        "parameters": {}
      },
      "input": [{ "lane": "questions", "from": "prompt_1" }],
      "ui": { "position": { "x": 900, "y": 200 }, "measured": { "width": 150, "height": 66 } }
    },
    {
      "id": "response_answers_1",
      "provider": "response_answers",
      "config": { "laneName": "answers" },
      "input": [{ "lane": "answers", "from": "llm_1" }],
      "ui": { "position": { "x": 1120, "y": 200 }, "measured": { "width": 150, "height": 66 } }
    }
  ],
  "project_id": "becd3a60-4b56-4c0f-92c0-af71dc2ec1f7",
  "viewport": { "x": 0, "y": 0, "zoom": 1 },
  "version": 1
}
