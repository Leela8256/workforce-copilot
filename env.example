# RocketRide engine
ROCKETRIDE_URI=http://localhost:5565
ROCKETRIDE_APIKEY=<any-non-empty-string-for-local-engine>

# OpenAI (used by every llm_openai node in the pipelines)
ROCKETRIDE_OPENAI_KEY=sk-...

# Jira (target for slack_to_jira_agent.pipe via tool_http_request)
ROCKETRIDE_JIRA_BASE_URL=https://your-site.atlassian.net
ROCKETRIDE_JIRA_EMAIL=you@example.com
ROCKETRIDE_JIRA_API_TOKEN=<atlassian-api-token>
ROCKETRIDE_JIRA_PROJECT_KEY=KAN
# Precomputed Basic auth header injected into the pipeline's tool_http_request node.
# Generate with: echo "Basic $(printf '%s' "$ROCKETRIDE_JIRA_EMAIL:$ROCKETRIDE_JIRA_API_TOKEN" | base64 | tr -d '\n')"
ROCKETRIDE_JIRA_AUTH_HEADER=Basic <base64-encoded-email:token>

# Slack (bot for inbound @-mentions via Socket Mode + outbound posts)
ROCKETRIDE_SLACK_BOT_TOKEN=xoxb-...
ROCKETRIDE_SLACK_SIGNING_SECRET=<32-hex-from-slack-app-Basic-Information>
ROCKETRIDE_SLACK_NOTIFY_CHANNEL=#workforce-copilot-demo
ROCKETRIDE_SLACK_APP_TOKEN=xapp-...

# Google (Gmail + Calendar via tool_http_request)
ROCKETRIDE_GOOGLE_CLIENT_ID=<from-google-cloud-console>.apps.googleusercontent.com
ROCKETRIDE_GOOGLE_CLIENT_SECRET=GOCSPX-...
ROCKETRIDE_GOOGLE_REFRESH_TOKEN=1//...
ROCKETRIDE_GOOGLE_USER_EMAIL=demo-account@gmail.com
# JSON map of per-participant refresh tokens for multi-user calendar free/busy lookups.
# Format: {"user1@example.com": "1//token1", "user2@example.com": "1//token2"}
# Run google_oauth_setup.py --participant for each additional participant to generate tokens.
ROCKETRIDE_CALENDAR_TOKENS_JSON={"user@example.com": "1//..."}
